# カスタム関数定義
#
# このファイルには汎用的なシェル関数を定義します


# =============================================================================
# ディレクトリ移動関数
# =============================================================================

# ディレクトリ履歴をインタラクティブに選択して移動
function cdi() {
    local dir

    # fzfが必要
    if ! command -v fzf >/dev/null 2>&1; then
        echo "Error: fzf is required for cdi command" >&2
        return 1
    fi

    dir=$(dirs -v | fzf | awk '{print $2}')

    # ディレクトリが選択されたら移動
    if [[ -n "$dir" ]]; then
        # ~を展開して移動
        eval cd "$dir"
    fi
}
