# エイリアス設定
#
# このファイルには各種エイリアスを定義します

# =============================================================================
# 基本エイリアス
# =============================================================================

# ls (exa)
alias ls='exa --time-style=long-iso -g'
alias ll='exa --git --time-style=long-iso -gl'
alias la='exa --git --time-style=long-iso -agl'
alias l1='exa -1'
alias l='exa -CF'           # カラム表示

# 設定の再読み込み
alias source-zshrc="source ~/.config/zsh/.zshrc"


# =============================================================================
# 安全化エイリアス
# =============================================================================

# ファイル操作の安全化（確認プロンプトを表示）
alias rm='rm -i'           # 削除前に確認
alias mv='mv -i'           # 移動前に確認
alias cp='cp -i'           # コピー前に確認


# =============================================================================
# Git操作エイリアス
# =============================================================================

# よく使うGit操作の短縮
# alias gs='git status'    # gsブランチ切り替え関数と競合するためコメントアウト
alias gst='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git log --oneline'
alias gu='git reset HEAD~1'  # 最後のコミットを元に戻す


# =============================================================================
# 履歴操作エイリアス
# =============================================================================

alias h='history'
alias hg='history | grep'


# =============================================================================
# 便利エイリアス
# =============================================================================

# 現在のディレクトリをFinderで開く
alias finder='open .'

# IPアドレス確認
alias myip='curl -s https://httpbin.org/ip | jq -r .origin'


# =============================================================================
# タイポ修正エイリアス
# =============================================================================

# clearコマンドのよくある間違い
alias clera='clear'
alias clar='clear'
alias clare='clear'
